---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}
---

<Layout title="Claude Code News — jikken.ai">
  <main class="max-w-2xl mx-auto px-6 py-20">

    <header class="mb-16">
      <a href="/" class="text-xs tracking-widest text-gray-300 uppercase mb-3 block hover:text-gray-500 transition-colors">← jikken.ai</a>
      <h1 class="text-lg font-medium text-gray-900 leading-snug mt-4">Claude Code News</h1>
      <p class="mt-3 text-sm text-gray-400">
        公式情報・アップデート・Tipsを自動収集してお届けします。
      </p>
    </header>

    <div class="border-t border-gray-100 mb-10"></div>

    <ul class="space-y-0">
      {sorted.length === 0 ? (
        <p class="text-sm text-gray-300">準備中...</p>
      ) : (
        sorted.map((item) => (
          <li class="border-b border-gray-50 last:border-0 py-4">
            <div class="flex items-baseline gap-4">
              <time class="text-xs text-gray-300 tabular-nums shrink-0 font-mono">
                {formatDate(item.data.date)}
              </time>
              <span class="ml-auto text-xs text-gray-200 shrink-0">
                {item.data.source}
              </span>
            </div>
            <a
              href={item.data.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group block mt-1"
            >
              <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 transition-colors leading-snug">
                {item.data.title}
              </span>
              <p class="mt-1 text-sm text-gray-400 leading-relaxed">
                {item.data.summary}
              </p>
            </a>
          </li>
        ))
      )}
    </ul>

  </main>
</Layout>
