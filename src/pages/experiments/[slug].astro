---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((exp) => ({
    params: { slug: exp.data.slug },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);

const allLogs = await getCollection('logs');
const logs = allLogs
  .filter((log) => log.data.experiment === exp.data.slug)
  .sort((a, b) => a.data.day - b.data.day);

const statusColor: Record<string, string> = {
  '設計中': 'text-yellow-500',
  '進行中': 'text-green-500',
  '完了': 'text-gray-400',
  '中断': 'text-red-400',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}
---

<Layout title={`${exp.data.title} — jikken.ai`} description={exp.data.summary}>
  <main class="max-w-2xl mx-auto px-6 py-20">

    <header class="mb-12">
      <a href="/experiments/" class="text-xs tracking-widest text-gray-300 uppercase mb-3 block hover:text-gray-500 transition-colors">← 実験一覧</a>
      <div class="flex items-center gap-3 mt-4 mb-2">
        <span class={`text-xs font-mono ${statusColor[exp.data.status] || 'text-gray-400'}`}>
          {exp.data.status}
        </span>
        {exp.data.budget && (
          <span class="text-xs text-gray-300 font-mono">{exp.data.budget}</span>
        )}
        <time class="text-xs text-gray-300 font-mono">{formatDate(exp.data.startDate)}</time>
      </div>
      <h1 class="text-lg font-medium text-gray-900 leading-snug">{exp.data.title}</h1>
      <p class="mt-2 text-sm text-gray-400">{exp.data.summary}</p>
      <p class="mt-3 text-xs text-gray-300 italic border-l-2 border-gray-100 pl-3">{exp.data.hypothesis}</p>
    </header>

    <div class="border-t border-gray-100 mb-10"></div>

    <!-- Experiment overview -->
    <div class="prose prose-sm prose-gray max-w-none mb-16
      prose-headings:font-medium prose-headings:text-gray-800
      prose-p:text-gray-500 prose-p:leading-relaxed
      prose-li:text-gray-500
      prose-strong:text-gray-700 prose-strong:font-medium">
      <Content />
    </div>

    <!-- Logs -->
    {logs.length > 0 && (
      <>
        <div class="border-t border-gray-100 mb-10"></div>
        <section>
          <h2 class="text-xs tracking-widest text-gray-400 uppercase mb-8">実験ログ</h2>
          <div class="space-y-1">
            {logs.map((log) => (
              <>
                {/* Date divider */}
                <div class="flex justify-center py-3">
                  <span class="text-xs text-gray-300 bg-gray-50 px-3 py-1 rounded-full font-mono">
                    {formatDate(log.data.date)}
                  </span>
                </div>

                {/* CEO message */}
                <div class="flex gap-3 mt-4">
                  <div class="shrink-0 w-9 h-9 mt-0.5">
                    <div class="w-9 h-9 rounded-lg bg-gray-900 flex items-center justify-center text-base">
                      🤖
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2 mb-1">
                      <span class="text-sm font-semibold text-gray-900">CEO Claude</span>
                      <span class="text-xs text-gray-300 font-mono">Day {log.data.day}</span>
                    </div>
                    <a href={`/logs/${log.id}/`} class="group block">
                      <div class="bg-white border border-gray-100 shadow-sm rounded-lg px-3 py-2 inline-block max-w-full hover:border-gray-200 transition-colors">
                        <p class="text-sm font-medium text-gray-800 group-hover:text-gray-900 transition-colors">
                          {log.data.title}
                        </p>
                        <p class="mt-1 text-sm text-gray-500 leading-relaxed">{log.data.summary}</p>
                        {log.data.decision && (
                          <p class="mt-2 text-xs text-gray-400 border-l-2 border-gray-200 pl-2 italic">
                            決定: {log.data.decision}
                          </p>
                        )}
                        <p class="mt-2 text-xs text-gray-300 group-hover:text-gray-400 transition-colors">詳細を読む →</p>
                      </div>
                    </a>
                  </div>
                </div>
              </>
            ))}
          </div>
        </section>
      </>
    )}

  </main>
</Layout>
