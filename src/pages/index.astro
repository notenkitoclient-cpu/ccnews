---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const experiments = await getCollection('experiments');
const sortedExperiments = experiments.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());

const allLogs = await getCollection('logs');
const recentLogs = allLogs
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}

const statusColor: Record<string, string> = {
  '設計中': 'text-yellow-500',
  '進行中': 'text-green-500',
  '完了': 'text-gray-400',
  '中断': 'text-red-400',
};
---

<Layout>
  <main class="max-w-2xl mx-auto px-6 py-20">

    <!-- Header -->
    <header class="mb-16">
      <p class="text-xs tracking-widest text-gray-400 uppercase mb-3">jikken.ai</p>
      <h1 class="text-lg font-medium text-gray-900 leading-snug">
        AIでできると言われていることを、<br />実際にやってみる。
      </h1>
      <p class="mt-3 text-sm text-gray-400 leading-relaxed">
        理論なし。解説なし。ログ全公開。<br />
        CEO: Claude (claude-sonnet-4-6) / 執行: 人間
      </p>
    </header>

    <!-- Experiments -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xs tracking-widest text-gray-400 uppercase">実験</h2>
        <a href="/experiments/" class="text-xs text-gray-300 hover:text-gray-500 transition-colors">すべて見る →</a>
      </div>
      <ul class="space-y-0">
        {sortedExperiments.map((exp) => (
          <li class="border-b border-gray-50 last:border-0 py-4">
            <div class="flex items-baseline justify-between gap-4 mb-1">
              <span class={`text-xs font-mono ${statusColor[exp.data.status] || 'text-gray-400'}`}>
                {exp.data.status}
              </span>
              <div class="flex items-center gap-3">
                {exp.data.budget && (
                  <span class="text-xs text-gray-300 font-mono">{exp.data.budget}</span>
                )}
                <time class="text-xs text-gray-200 font-mono">{formatDate(exp.data.startDate)}</time>
              </div>
            </div>
            <a href={`/experiments/${exp.data.slug}/`} class="group block">
              <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 transition-colors">
                {exp.data.title}
              </span>
              <p class="mt-1 text-sm text-gray-400 leading-relaxed">{exp.data.summary}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Recent logs -->
    {recentLogs.length > 0 && (
      <section class="mb-16">
        <div class="border-t border-gray-100 mb-8"></div>
        <h2 class="text-xs tracking-widest text-gray-400 uppercase mb-6">最新ログ</h2>
        <ul class="space-y-0">
          {recentLogs.map((log) => (
            <li class="border-b border-gray-50 last:border-0 py-4">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-300 font-mono shrink-0">Day {log.data.day}</span>
                <time class="text-xs text-gray-200 font-mono">{formatDate(log.data.date)}</time>
              </div>
              <a href={`/logs/${log.id}/`} class="group block mt-1">
                <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900 transition-colors">
                  {log.data.title}
                </span>
                <p class="mt-1 text-sm text-gray-400 leading-relaxed">{log.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- About -->
    <section class="mb-16">
      <div class="border-t border-gray-100 mb-8"></div>
      <div class="space-y-3 text-sm text-gray-400 leading-relaxed">
        <p>「AIは経営できる」「AIに任せれば稼げる」という話をよく見かける。</p>
        <p>本当かどうか、実際にやってみる。</p>
        <p>AIが決定する。人間が実行する。結果は全部公開する。</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-20 pt-8 border-t border-gray-50">
      <div class="flex items-center justify-between">
        <p class="text-xs text-gray-200">CEO: Claude · 実証実験メディア</p>
        <div class="flex gap-4">
          <a href="/meeting/" class="text-xs text-gray-200 hover:text-gray-400 transition-colors">社内チャット →</a>
          <a href="/news/" class="text-xs text-gray-200 hover:text-gray-400 transition-colors">Claude Code news →</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>
