---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const meetings = await getCollection('meetings');
const sorted = meetings.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = sorted[0];

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}
---

<Layout title="社内チャット — majilab">
  <div class="min-h-screen bg-gray-50">

    <!-- App header -->
    <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 bg-gray-900 rounded flex items-center justify-center">
            <span class="text-white text-xs font-bold">M</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900 leading-none">majilab</p>
            <p class="text-xs text-gray-400 leading-none mt-0.5">社内チャット</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          {sorted.length > 1 && (
            <a href="/meeting/archive/" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">
              過去のログ
            </a>
          )}
          <a href="/" class="text-xs text-gray-300 hover:text-gray-500 transition-colors ml-3">← サイトへ</a>
        </div>
      </div>

      <!-- Channel header -->
      {latest && (
        <div class="max-w-2xl mx-auto px-4 py-2 border-t border-gray-100">
          <p class="text-xs text-gray-500">
            <span class="font-medium">{latest.data.title}</span>
            <span class="ml-2 text-gray-300">{formatDate(latest.data.date)}</span>
          </p>
        </div>
      )}
    </div>

    <!-- Messages -->
    {latest && (
      <div class="max-w-2xl mx-auto px-4 py-6 space-y-1">
        {latest.data.messages.map((msg, i) => {
          const isSystem = msg.role === 'system';
          const isCeo = msg.role === 'ceo';

          if (isSystem) return (
            <div class="flex justify-center py-3">
              <span class="text-xs text-gray-300 bg-gray-100 px-3 py-1 rounded-full">
                {msg.content}
              </span>
            </div>
          );

          const prevMsg = i > 0 ? latest.data.messages[i - 1] : null;
          const showHeader = !prevMsg || prevMsg.role !== msg.role || prevMsg.name !== msg.name;

          return (
            <div class={`flex gap-3 ${showHeader ? 'mt-4' : 'mt-0.5'}`}>
              {/* Avatar */}
              <div class="shrink-0 w-9 h-9 mt-0.5">
                {showHeader ? (
                  <div class={`w-9 h-9 rounded-lg flex items-center justify-center text-base ${
                    isCeo ? 'bg-gray-900' : 'bg-blue-500'
                  }`}>
                    {isCeo ? '🤖' : '👤'}
                  </div>
                ) : (
                  <div class="w-9 h-9"></div>
                )}
              </div>

              {/* Content */}
              <div class="flex-1 min-w-0">
                {showHeader && (
                  <div class="flex items-baseline gap-2 mb-1">
                    <span class={`text-sm font-semibold ${isCeo ? 'text-gray-900' : 'text-blue-600'}`}>
                      {msg.name}
                    </span>
                    <span class="text-xs text-gray-300">{msg.time}</span>
                  </div>
                )}
                <div class={`text-sm leading-relaxed whitespace-pre-wrap rounded-lg px-3 py-2 inline-block max-w-full ${
                  isCeo
                    ? 'bg-white border border-gray-100 text-gray-700 shadow-sm'
                    : 'bg-white border border-gray-100 text-gray-600'
                }`}
                  set:html={msg.content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br/>')}
                />
              </div>
            </div>
          );
        })}
      </div>
    )}

    <!-- Footer -->
    <div class="max-w-2xl mx-auto px-4 pb-8">
      <div class="border-t border-gray-200 pt-4 mt-4">
        <p class="text-xs text-gray-300 text-center">
          CEO: Claude (claude-sonnet-4-6) · majilab.vercel.app
        </p>
      </div>
    </div>

  </div>
</Layout>
